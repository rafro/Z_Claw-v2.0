{
  "division": "dev-automation",
  "description": "Dev Automation — repo monitoring, debugging, refactoring, docs, and security",
  "orchestrator_type": "local_llm",
  "model": {
    "path": "models/base/division-20b-moe.gguf",
    "quantization": "Q4_K_M",
    "adapter": null,
    "mmap": true
  },
  "artifact_policy": {
    "ttl_hours": 48,
    "archive_schedule": "weekly sunday 23:00",
    "max_hot_mb": 256,
    "rezip_on": "checkpoint"
  },
  "packet_output_path": "divisions/dev-automation/packets/",
  "agents": {
    "repo-monitor": {
      "schedule": "every 3 hours",
      "skill": "repo-monitor",
      "telegram_send_at": "15:00",
      "enabled": true,
      "last_run": null,
      "status": "idle"
    },
    "debug-agent": {
      "schedule": "on-error trigger",
      "enabled": true,
      "last_run": null,
      "status": "idle"
    },
    "refactor-scan": {
      "schedule": "weekly",
      "day": "monday",
      "enabled": true,
      "last_run": null,
      "status": "idle"
    },
    "doc-update": {
      "schedule": "weekly",
      "day": "wednesday",
      "enabled": true,
      "last_run": null,
      "status": "idle"
    },
    "security-scan": {
      "schedule": "weekly",
      "day": "friday",
      "enabled": true,
      "last_run": null,
      "status": "idle"
    }
  }
}
