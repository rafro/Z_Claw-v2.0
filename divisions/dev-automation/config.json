{
  "division": "dev-automation",
  "description": "Dev Automation — repo monitoring, debugging, refactoring, docs, and security",
  "orchestrator_type": "python_runtime",
  "model": {
    "tier2_host": "http://localhost:11434",
    "tier2_model": "qwen2.5:14b-instruct-q4_K_M",
    "tier1_fallback_model": "qwen2.5:7b-instruct-q4_K_M",
    "notes": "Tier 2 preferred (friend's 9070 XT). Falls back to 7B local, then Tier 3 API. See llm-routing.md."
  },
  "artifact_policy": {
    "ttl_hours": 48,
    "archive_schedule": "weekly sunday 23:00",
    "max_hot_mb": 256,
    "rezip_on": "checkpoint"
  },
  "packet_output_path": "divisions/dev-automation/packets/",
  "agents": {
    "repo-monitor": {
      "schedule": "every 3 hours",
      "skill": "repo-monitor",
      "telegram_send_at": "15:00",
      "enabled": true,
      "last_run": null,
      "status": "idle"
    },
    "debug-agent": {
      "schedule": "on-error trigger",
      "enabled": true,
      "last_run": null,
      "status": "idle"
    },
    "refactor-scan": {
      "schedule": "weekly",
      "day": "monday",
      "enabled": true,
      "last_run": null,
      "status": "idle"
    },
    "doc-update": {
      "schedule": "weekly",
      "day": "wednesday",
      "enabled": true,
      "last_run": null,
      "status": "idle"
    },
    "security-scan": {
      "schedule": "weekly",
      "day": "friday",
      "enabled": true,
      "last_run": null,
      "status": "idle"
    }
  }
}
