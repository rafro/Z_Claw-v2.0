{
  "division": "opportunity",
  "description": "Opportunity Discovery — job intake, filtering, and funding discovery",
  "orchestrator_type": "local_llm",
  "model": {
    "path": "models/base/division-20b-moe.gguf",
    "quantization": "Q4_K_M",
    "adapter": null,
    "mmap": true
  },
  "artifact_policy": {
    "ttl_hours": 72,
    "archive_schedule": "weekly sunday 23:00",
    "max_hot_mb": 512,
    "rezip_on": "checkpoint"
  },
  "packet_output_path": "divisions/opportunity/packets/",
  "agents": {
    "job-intake": {
      "schedule": "every 3 hours",
      "skill": "job-intake",
      "enabled": true,
      "last_run": null,
      "status": "idle"
    },
    "hard-filter": {
      "schedule": "after each job-intake run",
      "skill": "hard-filter",
      "enabled": true,
      "last_run": null,
      "status": "idle"
    },
    "funding-finder": {
      "schedule": "daily 14:00",
      "skill": "funding-finder",
      "enabled": true,
      "last_run": null,
      "status": "idle"
    },
    "tier-report": {
      "schedule": "after each intake run",
      "enabled": true,
      "last_run": null,
      "status": "idle"
    }
  }
}
