{
  "division": "personal",
  "description": "Personal Optimization — health logging, trade tracking, performance correlation, burnout monitoring",
  "orchestrator_type": "python_runtime",
  "model": {
    "tier1_privacy_host": "http://localhost:11434",
    "tier1_privacy_model": "llama3.1:8b-q4_K_M",
    "tier1_analysis_model": "qwen2.5:7b-instruct-q4_K_M",
    "notes": "health-logger uses Llama 3.1 8B — PRIVACY, local only, no API fallback. perf-correlation uses Qwen2.5 7B."
  },
  "artifact_policy": {
    "ttl_hours": 336,
    "archive_schedule": "monthly",
    "max_hot_mb": 128,
    "rezip_on": "checkpoint",
    "sensitivity": "high"
  },
  "packet_output_path": "divisions/personal/packets/",
  "agents": {
    "health-logger": {
      "schedule": "daily 18:00",
      "skill": "health-logger",
      "enabled": true,
      "last_run": null,
      "status": "idle"
    },
    "trade-tracker": {
      "schedule": "after each manual session",
      "skill": "trading-report",
      "enabled": true,
      "last_run": null,
      "status": "idle"
    },
    "perf-correlation": {
      "schedule": "daily 20:00",
      "skill": "perf-correlation",
      "enabled": true,
      "last_run": null,
      "status": "idle"
    },
    "burnout-monitor": {
      "schedule": "daily",
      "time": "09:00",
      "enabled": true,
      "last_run": null,
      "status": "idle"
    }
  }
}
