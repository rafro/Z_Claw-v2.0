# Copy to .env and fill in your values
# cp .env.example .env

# ── Ollama (local, your 9070 XT) ────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
MODEL_14B_HOST=http://localhost:11434

# Optional model overrides (defaults are set in config.py)
# MODEL_7B=qwen2.5:7b-instruct-q4_K_M
# MODEL_8B=llama3.1:8b-instruct-q4_K_M
# MODEL_CODER_7B=qwen2.5-coder:7b-instruct-q4_K_M
# MODEL_CODER_14B=qwen2.5-coder:14b-instruct-q4_K_M

# ── API keys (optional — only needed for cloud fallback) ─────────────────────
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
CLAUDE_MODEL=claude-opus-4-6

# ── Market Data Provider ────────────────────────────────────────────────────
# auto = best available (tradovate > databento > twelvedata > polygon > alpaca > csv > yfinance)
MARKET_DATA_PROVIDER=auto

# Tradovate (free with MFF/Apex — actual CME futures data)
TRADOVATE_USERNAME=
TRADOVATE_PASSWORD=
TRADOVATE_APP_ID=
TRADOVATE_CID=
# TRADOVATE_DEMO=true    # Uncomment for demo/evaluation accounts

# Alpaca Markets (free — unlimited 1-min stock/ETF history)
# Sign up: https://alpaca.markets
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Twelve Data (free tier — 3+ years of 1-minute ETF data, 800 credits/day)
# Works internationally (Canada, EU, etc.) — best free option for daytrading
# Sign up: https://twelvedata.com
TWELVEDATA_API_KEY=

# Polygon.io (free tier available — stocks, ETFs, and CME futures)
# Works internationally (Canada, EU, etc.)
# Sign up: https://polygon.io (or massive.com)
POLYGON_API_KEY=

# Databento (paid — actual CME futures data, institutional quality)
# Sign up: https://databento.com
DATABENTO_API_KEY=

# CSV data directory (for TradingView/NinjaTrader exports)
# MARKET_DATA_CSV_DIR=state/trading/historical

# ── Opportunity division ─────────────────────────────────────────────────────
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ── Mission Control notifications (Telegram) ─────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── OP-Sec division ─────────────────────────────────────────────────────────
HIBP_API_KEY=

# ── Production division ─────────────────────────────────────────────────────
# ComfyUI for image/video generation (default: http://127.0.0.1:8188)
# COMFYUI_URL=http://127.0.0.1:8188

# QVAC BitNet LoRA fine-tuning path (default: C:/Users/Tyler/qvac-fabric-llm.cpp)
# QVAC_PATH=C:/Users/Tyler/qvac-fabric-llm.cpp

# ── Discord notifications (escalation alerts) ──────────────────────────────
DISCORD_WEBHOOK_URL=

# ── Mission Control Mobile ────────────────────────────────────────────────────
# Required to enable mobile access. Set a strong random token (32+ chars).
# Mobile clients must send: Authorization: Bearer <MOBILE_TOKEN>
# Desktop dashboard (localhost) is exempt and never needs this token.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MOBILE_TOKEN=

# ── Auto-Fix (code automation — all disabled by default) ────────────────────
# AUTO_FIX_ENABLED=true       # Enable auto-fix to apply scan findings
# AUTO_APPLY_ENABLED=true     # Enable dev pipeline auto-apply (skip approval for high-confidence)
# AUTO_GIT_PUSH=false         # Push auto-commits to remote (default: false, commits only)
