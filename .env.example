# Copy to .env and fill in your values
# cp .env.example .env

# ── Ollama (local, your 9070 XT) ────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
MODEL_14B_HOST=http://localhost:11434

# Optional model overrides (defaults are set in config.py)
# MODEL_7B=qwen2.5:7b-instruct-q4_K_M
# MODEL_8B=llama3.1:8b-instruct-q4_K_M
# MODEL_CODER_7B=qwen2.5-coder:7b-instruct-q4_K_M
# MODEL_CODER_14B=qwen2.5-coder:14b-instruct-q4_K_M

# ── API keys (optional — only needed for cloud fallback) ─────────────────────
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
CLAUDE_MODEL=claude-opus-4-6

# ── Opportunity division ─────────────────────────────────────────────────────
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ── Mission Control notifications (Telegram) ─────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Mission Control Mobile ────────────────────────────────────────────────────
# Required to enable mobile access. Set a strong random token (32+ chars).
# Mobile clients must send: Authorization: Bearer <MOBILE_TOKEN>
# Desktop dashboard (localhost) is exempt and never needs this token.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MOBILE_TOKEN=
